{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bitbox-links",
  "main": ".output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public",
    "html_handling": "drop-trailing-slash"
  },
  "compatibility_date": "2025-05-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "keep_vars": true,
  "upload_source_maps": true,
  "observability": {
    "logs": {
      "enabled": true
    },
    "traces": {
      "enabled": true
    }
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "sink-bitbox"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "preview_id": "283734d55c0f46e7bf593eb8f0f9db91",
      "id": "283734d55c0f46e7bf593eb8f0f9db91" // IMPORTANT: Change this to your KV namespace ID
    }
  ]
}
